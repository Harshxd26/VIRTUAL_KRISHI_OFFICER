# Application Configuration
APP_NAME="Virtual Krishi Officer API"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=2

# Database
DATABASE_URL=sqlite:///./app/data/agri_advisory.db

# Redis Cache (optional - leave empty to use in-memory cache)
REDIS_URL=
CACHE_TTL=3600
ENABLE_CACHE=True

# External APIs
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast
AGMARKNET_BASE_URL=https://agmarknet.gov.in

# LLM Configuration
# Option 1: Local Ollama (recommended for development)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral:7b
USE_GROQ=False

# Option 2: Groq API (free tier - for production without local GPU)
# Get free API key from https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# LLM Settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_TIMEOUT=30

# Vector Database
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_INDEX_PATH=./app/data/faiss_index/knowledge_base.index
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.3

# Authentication (change SECRET_KEY in production!)
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_PER_MINUTE=20
RATE_LIMIT_PER_HOUR=500

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Data Paths
DATA_DIR=./app/data
KNOWLEDGE_BASE_DIR=./app/data/knowledge_base
CROPS_DB_PATH=./app/data/crops.json
SCHEMES_DB_PATH=./app/data/schemes.json

# Features
ENABLE_WEATHER=True
ENABLE_MARKET_PRICES=True
ENABLE_SCHEMES=True
ENABLE_IMAGE_ANALYSIS=False

# Monitoring
ENABLE_METRICS=True
METRICS_PORT=9090