"""
Weather Service - Integration with Open-Meteo API
Provides free weather forecasts and historical data
"""

import aiohttp
from typing import Dict, Optional
from datetime import datetime, timedelta
import asyncio
from openmeteo_py import OpenMeteo
from app.config import settings

from app.utils.logger import setup_logging

logger = setup_logging()


class WeatherService:
    """Weather data service using Open-Meteo API"""
    
    def __init__(self):
        self.base_url = "https://api.open-meteo.com/v1"
        self.session: Optional[aiohttp.ClientSession] = None
        self.timeout = aiohttp.ClientTimeout(total=10)
    
    async def _get_session(self) -> aiohttp.ClientSession:
        """Get or create HTTP session"""
        if self.session is None or self.session.closed:
            self.session = aiohttp.ClientSession(timeout=self.timeout)
        return self.session
    
    async def close(self):
        """Close HTTP session"""
        if self.session and not self.session.closed:
            await self.session.close()
    
    async def get_forecast(
        self,
        latitude: float,
        longitude: float,
        days: int = 7
    ) -> Dict:
        """
        Get weather forecast for location
        
        Args:
            latitude: Latitude coordinate
            longitude: Longitude coordinate
            days: Number of forecast days (1-16)
        
        Returns:
            Weather forecast data with agricultural advisories
        """
        try:
            session = await self._get_session()
            
            # Parameters for agricultural use case
            params = {
                "latitude": latitude,
                "longitude": longitude,
                "current": [
                    "temperature_2m",
                    "relative_humidity_2m",
                    "precipitation",
                    "weather_code",
                    "wind_speed_10m"
                ],
                "daily": [
                    "temperature_2m_max",
                    "temperature_2m_min",
                    "precipitation_sum",
                    "precipitation_probability_max",
                    "weather_code",
                    "wind_speed_10m_max",
                    "wind_direction_10m_dominant",
                    "sunrise",
                    "sunset"
                ],
                "timezone": "auto",
                "forecast_days": min(days, 7)  # Free tier: max 7 days
            }
            
            async with session.get(f"{self.base_url}/forecast", params=params) as response:
                if response.status != 200:
                    logger.error(f"Weather API error: {response.status}")
                    return self._get_fallback_data()
                
                data = await response.json()
                
                # Process and add agricultural advisories
                processed_data = self._process_weather_data(data)
                
                logger.info(f"✅ Weather forecast fetched for ({latitude}, {longitude})")
                return processed_data
                
        except asyncio.TimeoutError:
            logger.error("Weather API timeout")
            return self._get_fallback_data()
        except Exception as e:
            logger.error(f"Weather API error: {e}")
            return self._get_fallback_data()
    
    async def get_historical(
        self,
        latitude: float,
        longitude: float,
        start_date: str,
        end_date: str
    ) -> Dict:
        """
        Get historical weather data
        
        Args:
            latitude: Latitude coordinate
            longitude: Longitude coordinate
            start_date: Start date (YYYY-MM-DD)
            end_date: End date (YYYY-MM-DD)
        """
        try:
            session = await self._get_session()
            
            params = {
                "latitude": latitude,
                "longitude": longitude,
                "start_date": start_date,
                "end_date": end_date,
                "daily": [
                    "temperature_2m_max",
                    "temperature_2m_min",
                    "precipitation_sum"
                ],
                "timezone": "auto"
            }
            
            async with session.get(f"{self.base_url}/forecast", params=params) as response:
                if response.status != 200:
                    return {"error": "Historical data unavailable"}
                
                data = await response.json()
                logger.info(f"✅ Historical weather fetched for ({latitude}, {longitude})")
                return data
                
        except Exception as e:
            logger.error(f"Historical weather error: {e}")
            return {"error": str(e)}
    
    def _process_weather_data(self, raw_data: Dict) -> Dict:
        """
        Process raw weather data and add agricultural advisories
        """
        current = raw_data.get("current", {})
        daily = raw_data.get("daily", {})
        
        # Generate agricultural advisories
        advisories = []
        
        # Temperature advisory
        current_temp = current.get("temperature_2m", 0)
        if current_temp > 35:
            advisories.append({
                "type": "heat_stress",
                "severity": "high",
                "message": "High temperature alert. Ensure adequate irrigation for crops. Avoid pesticide application during peak heat.",
                "recommendation": "Irrigate early morning or late evening. Provide shade for sensitive crops."
            })
        elif current_temp < 10:
            advisories.append({
                "type": "cold_stress",
                "severity": "medium",
                "message": "Low temperature warning. Protect sensitive crops from frost damage.",
                "recommendation": "Consider frost protection measures like mulching or covering."
            })
        
        # Precipitation advisory
        upcoming_rain = daily.get("precipitation_sum", [])
        if upcoming_rain and upcoming_rain[0] > 10:
            advisories.append({
                "type": "heavy_rain",
                "severity": "medium",
                "message": "Heavy rainfall expected. Postpone fertilizer and pesticide applications.",
                "recommendation": "Ensure proper drainage. Delay sowing if planned."
            })
        elif all(rain < 1 for rain in upcoming_rain[:3]):
            advisories.append({
                "type": "dry_spell",
                "severity": "medium",
                "message": "Dry period ahead. Plan irrigation accordingly.",
                "recommendation": "Check soil moisture regularly. Consider water conservation techniques."
            })
        
        # Wind advisory
        wind_speed = current.get("wind_speed_10m", 0)
        if wind_speed > 20:
            advisories.append({
                "type": "high_wind",
                "severity": "low",
                "message": "High wind speeds. Avoid pesticide spraying to prevent drift.",
                "recommendation": "Postpone spraying activities. Secure loose structures."
            })
        
        # Build processed response
        processed = {
            "location": {
                "latitude": raw_data.get("latitude"),
                "longitude": raw_data.get("longitude"),
                "timezone": raw_data.get("timezone")
            },
            "current": {
                "temperature": current.get("temperature_2m"),
                "humidity": current.get("relative_humidity_2m"),
                "precipitation": current.get("precipitation"),
                "wind_speed": current.get("wind_speed_10m"),
                "weather_description": self._get_weather_description(current.get("weather_code"))
            },
            "forecast": self._format_daily_forecast(daily),
            "agricultural_advisories": advisories,
            "summary": self._generate_summary(current, daily, advisories)
        }
        
        return processed
    
    def _format_daily_forecast(self, daily: Dict) -> list:
        """Format daily forecast data"""
        if not daily or "time" not in daily:
            return []
        
        forecast = []
        for i in range(len(daily["time"])):
            day_data = {
                "date": daily["time"][i],
                "temperature_max": daily.get("temperature_2m_max", [])[i] if i < len(daily.get("temperature_2m_max", [])) else None,
                "temperature_min": daily.get("temperature_2m_min", [])[i] if i < len(daily.get("temperature_2m_min", [])) else None,
                "precipitation": daily.get("precipitation_sum", [])[i] if i < len(daily.get("precipitation_sum", [])) else None,
                "precipitation_probability": daily.get("precipitation_probability_max", [])[i] if i < len(daily.get("precipitation_probability_max", [])) else None,
                "weather_description": self._get_weather_description(
                    daily.get("weather_code", [])[i] if i < len(daily.get("weather_code", [])) else None
                )
            }
            forecast.append(day_data)
        
        return forecast
    
    def _get_weather_description(self, code: Optional[int]) -> str:
        """Convert WMO weather code to description"""
        weather_codes = {
            0: "Clear sky",
            1: "Mainly clear",
            2: "Partly cloudy",
            3: "Overcast",
            45: "Foggy",
            48: "Depositing rime fog",
            51: "Light drizzle",
            53: "Moderate drizzle",
            55: "Dense drizzle",
            61: "Slight rain",
            63: "Moderate rain",
            65: "Heavy rain",
            71: "Slight snow",
            73: "Moderate snow",
            75: "Heavy snow",
            77: "Snow grains",
            80: "Slight rain showers",
            81: "Moderate rain showers",
            82: "Violent rain showers",
            85: "Slight snow showers",
            86: "Heavy snow showers",
            95: "Thunderstorm",
            96: "Thunderstorm with slight hail",
            99: "Thunderstorm with heavy hail"
        }
        return weather_codes.get(code, "Unknown")
    
    def _generate_summary(self, current: Dict, daily: Dict, advisories: list) -> str:
        """Generate human-readable weather summary"""
        temp = current.get("temperature_2m", 0)
        description = self._get_weather_description(current.get("weather_code"))
        
        summary = f"Current conditions: {description} with temperature around {temp}°C. "
        
        if advisories:
            summary += f"{len(advisories)} agricultural advisory(ies) in effect. "
        
        # Add forecast summary
        if daily.get("precipitation_sum"):
            upcoming_rain = sum(daily["precipitation_sum"][:3])
            if upcoming_rain > 0:
                summary += f"Expect {upcoming_rain:.1f}mm rainfall in next 3 days. "
        
        return summary.strip()
    
    def _get_fallback_data(self) -> Dict:
        """Return fallback data when API fails"""
        return {
            "location": {},
            "current": {},
            "forecast": [],
            "agricultural_advisories": [],
            "summary": "Weather data temporarily unavailable. Please try again later.",
            "error": "Weather service unavailable"
        }


# Global instance
weather_service = WeatherService()